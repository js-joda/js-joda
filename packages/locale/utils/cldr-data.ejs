import { registerLocaleData } from '@js-joda/locale';
<% locales.forEach(function(locale){ -%>
import  <%- locale.replace(/-/g, '_') _%>_cg from 'cldr-data/main/<%- locale %>/ca-gregorian.json';
import  <%- locale.replace(/-/g, '_') _%>_tzn from 'cldr-data/main/<%- locale %>/timeZoneNames.json';
<% }); -%>

<% locales.forEach(function(locale){ -%>
registerLocaleData('main/<%- locale %>/ca-gregorian.json', <%- locale.replace(/-/g, '_') %>_cg);
registerLocaleData('main/<%- locale %>/timeZoneNames.json', <%- locale.replace(/-/g, '_') %>_tzn);
<% }); -%>